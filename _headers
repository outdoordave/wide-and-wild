# Cloudflare Pages: Cache-Steuerung
# Inhalts-Dateien (vom CMS gepflegt) sollen NIE gecacht werden,
# damit Änderungen sofort sichtbar sind.

/content/*
  Cache-Control: no-store, must-revalidate

/admin/*
  Cache-Control: no-store, must-revalidate

# Die index.html (der Code) ebenfalls immer frisch laden,
# damit Code-Updates sofort greifen.
/
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

# Hochgeladene Bilder/Videos dürfen gecacht werden (ändern sich selten,
# und neue Bilder haben neue Dateinamen). Das hält die Seite schnell.
/uploads/*
  Cache-Control: public, max-age=3600
